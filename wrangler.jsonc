{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "z-super-cars",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "z-super-cars"
    }
  ]
}
